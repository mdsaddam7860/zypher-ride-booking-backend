# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ride_booking

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Mapping provider (Google Directions API, or swap for OSRM/Mapbox).
# Leave BLANK to use the built-in haversine-distance fallback (fine for local/dev testing).
# Only set this to a real key once you've enabled the Directions API + billing in Google Cloud.
GOOGLE_MAPS_API_KEY=

# Fare calculation
FARE_BASE_FEE=2.50
FARE_PER_KM=0.90
FARE_PER_MINUTE=0.15
FARE_CURRENCY=INR
FARE_ESTIMATE_TTL_MINUTES=5

# Push notifications (Firebase Cloud Messaging, HTTP v1 API via firebase-admin)
# Provide ONE of the following. Leave both blank to keep notifications
# stubbed (logged only, nothing sent).
#   1) Full service account JSON as a string, or base64-encoded:
FIREBASE_SERVICE_ACCOUNT_JSON=
#   2) Path to the service account JSON file on disk (local dev):
FIREBASE_SERVICE_ACCOUNT_PATH=
# Optional — usually inferred from the service account JSON itself.
FIREBASE_PROJECT_ID=

# Logging (Winston -> console + local files + Better Stack)
# Create a source at https://betterstack.com/logs and paste its token here.
# Leave blank to skip shipping logs to Better Stack (console/file logs still work).
BETTERSTACK_SOURCE_TOKEN=
# Only needed if you're on a regional/self-hosted Better Stack ingesting host.
BETTERSTACK_INGESTING_HOST=
